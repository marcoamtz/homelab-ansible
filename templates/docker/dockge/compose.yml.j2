services:
  dockge:
    image: louislam/dockge:1
    restart: unless-stopped
    ports:
      - "{{ dockge_port }}:5001"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
      - {{ dockge_data_dir }}:/app/data
      - {{ dockge_stacks_dir }}:/opt/stacks
    environment:
      DOCKGE_STACKS_DIR: /opt/stacks
