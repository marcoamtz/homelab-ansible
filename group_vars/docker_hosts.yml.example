---
# === Paths ===
# Where Dockge stores its own data
dockge_data_dir: "/opt/dockge"
# Where Dockge looks for compose stacks (each stack in a subdirectory)
dockge_stacks_dir: "/opt/stacks"
# Bind mounts from Proxmox host NFS (configured in LXC config, not playbook)
nas_media_path: "/mnt/nas/media"
nas_complete_path: "/mnt/nas/complete"

# === Dockge ===
dockge_port: 5001

# === Emby ===
emby_port_http: 8096
emby_port_https: 8920
emby_config_dir: "/opt/stacks/emby/config"
emby_media_dir: "{{ nas_media_path }}"
# Transcoding temp on tank ZFS bind mount (fast NVMe, can be several GB per stream)
emby_transcode_dir: "/mnt/tank/emby-transcode"
# UID/GID for file permissions (match your media file ownership)
emby_uid: "1000"
emby_gid: "1000"

# === Speedtest Tracker ===
speedtest_port: 8088
speedtest_url: "192.168.1.220"
speedtest_config_dir: "/opt/stacks/speedtest-tracker/config"
speedtest_puid: "1000"
speedtest_pgid: "1000"
# Generate at https://speedtest-tracker.dev/
speedtest_app_key: "base64:XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
speedtest_app_name: "Internet Tracker"
speedtest_public_dashboard: "true"
# Cron schedule for speed tests (default: every hour at minute 6)
speedtest_schedule: "6 */1 * * *"
# Comma-separated Ookla server IDs (find yours at https://www.speedtest.net/speedtest-servers.php)
speedtest_servers: ""
speedtest_prune_days: "90"
# Email notifications (optional)
speedtest_mail_host: "smtp.example.com"
speedtest_mail_encryption: "ssl"
speedtest_mail_port: "465"
speedtest_mail_username: "user@example.com"
speedtest_mail_password: "XXXXXXXXXXXXXXXX"
speedtest_mail_from: "user@example.com"

# === qBittorrent ===
qbittorrent_port_webui: 8080
qbittorrent_port_torrent: 6881
qbittorrent_config_dir: "/opt/stacks/qbittorrent/config"
# Incomplete downloads on tank ZFS bind mount (fast NVMe, not limited by root disk)
qbittorrent_incomplete_dir: "/mnt/tank/incomplete"
# Completed downloads on Synology NFS
qbittorrent_complete_dir: "{{ nas_complete_path }}"
# PUID/PGID for linuxserver images
qbittorrent_puid: "1000"
qbittorrent_pgid: "1000"

# === Docker ===
docker_timezone: "America/Mexico_City"
# ULA subnet for Docker's default bridge network
docker_ipv6_cidr: "fd00:dead:beef::/48"
# ULA pool for Docker Compose networks (each gets a /64 from this range)
docker_ipv6_pool: "fd00:dead:cafe::/48"
